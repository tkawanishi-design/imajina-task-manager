<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>マネージャーダッシュボード - imajina Task Manager</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="header">
    <img src="/img/imajina_logo_K0.png" alt="imajina" class="header-logo">
    <div class="header-right">
      <span class="phase-badge"><%= phase.label %></span>
      <% if (phase.remainToDeadline > 0) { %>
        <span class="time-badge" style="font-size:11px;color:rgba(255,255,255,0.95);background:rgba(255,255,255,0.15);padding:4px 10px;border-radius:12px;line-height:1.4;">
          18時まで <strong><%= Math.floor(phase.remainToDeadline / 60) %>h<%= phase.remainToDeadline % 60 %>m</strong>
          ｜20時まで <strong><%= Math.floor(phase.remainToFinal / 60) %>h<%= phase.remainToFinal % 60 %>m</strong>
        </span>
      <% } else if (phase.remainToFinal > 0) { %>
        <span class="time-badge" style="font-size:11px;color:#fca5a5;background:rgba(255,0,0,0.2);padding:4px 10px;border-radius:12px;font-weight:700;">
          残業中｜20時まで <strong><%= Math.floor(phase.remainToFinal / 60) %>h<%= phase.remainToFinal % 60 %>m</strong>
        </span>
      <% } %>
      <a href="/team-setup?date=<%= selectedDate %>" class="btn-logout" style="background:rgba(255,255,255,0.25);">チーム編成</a>
      <div class="header-user">
        <label class="avatar-upload">
          <%- avatarHtml(user, 'sm') %>
          <input type="file" accept="image/*" onchange="uploadAvatar(this, <%= user.id %>)">
          <div class="avatar-overlay">変更</div>
        </label>
        <span class="user-name"><%= user.name %> (マネージャー)</span>
      </div>
      <a href="/logout" class="btn-logout">ログアウト</a>
    </div>
  </div>

  <div class="container">
    <!-- Date selector -->
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px;">
      <input type="date" id="date-select" value="<%= selectedDate %>" style="padding:8px 12px;border-radius:8px;border:1px solid var(--gray-300);font-size:14px;" onchange="location.href='/manager?date='+this.value">
      <% if (selectedDate !== today) { %>
        <a href="/manager" class="btn btn-sm btn-outline">今日に戻る</a>
      <% } %>
      <span style="color:var(--gray-500);font-size:14px;"><%= selectedDate %> のタスク状況</span>
    </div>

    <!-- Alerts -->
    <% if (alerts.length > 0) { %>
    <div class="alert-panel" id="alert-panel">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
        <h3 style="font-size:15px;color:var(--gray-700);">Alerts (<span id="alert-count"><%= alerts.length %></span>件)</h3>
        <button class="btn btn-sm btn-outline" onclick="dismissAllAlerts()" style="font-size:11px;">すべて確認済みにする</button>
      </div>
      <% alerts.forEach((a, ai) => { %>
        <div class="alert-item <%= a.type %>" id="alert-item-<%= ai %>" data-alert-key="<%= a.type %>-<%= a.userId %>-<%= selectedDate %>" style="cursor:pointer;flex-wrap:wrap;" onclick="toggleAlertReply(<%= ai %>)">
          <span class="alert-icon">
            <%= a.type === 'delay' ? '!' : a.type === 'warning' ? '!!' : a.type === 'time-danger' ? '!!!' : a.type === 'time-warn' ? '!!' : '?' %>
          </span>
          <span style="flex:1;"><strong>[<%= a.teamName %>]</strong> <%= a.message %></span>
          <span style="font-size:12px;opacity:0.6;margin-left:8px;">Reply</span>
          <button class="alert-dismiss-btn" onclick="event.stopPropagation();dismissAlert(<%= ai %>)" title="確認済み">✕</button>
          <div class="alert-reply" id="alert-reply-<%= ai %>" style="display:none;width:100%;margin-top:8px;" onclick="event.stopPropagation()">
            <div style="display:flex;gap:8px;align-items:center;">
              <input type="text" class="alert-reply-input" id="alert-input-<%= ai %>" placeholder="<%= a.userName %>さんにコメント..." style="flex:1;padding:8px 12px;border-radius:8px;border:1px solid var(--gray-300);font-size:13px;">
              <button class="btn btn-sm btn-primary" onclick="sendAlertComment(<%= ai %>, <%= a.taskId %>, '<%= a.userName %>')">送信</button>
            </div>
            <div style="display:flex;gap:6px;margin-top:6px;flex-wrap:wrap;">
              <button class="btn btn-sm btn-outline" style="font-size:11px;padding:4px 8px;" onclick="quickFill(<%= ai %>, '早めに進めてください！')">早めに進めて</button>
              <button class="btn btn-sm btn-outline" style="font-size:11px;padding:4px 8px;" onclick="quickFill(<%= ai %>, '優先的に対応をお願いします')">優先対応して</button>
              <button class="btn btn-sm btn-outline" style="font-size:11px;padding:4px 8px;" onclick="quickFill(<%= ai %>, '今日は外して明日に回してOKです')">明日に回してOK</button>
              <button class="btn btn-sm btn-outline" style="font-size:11px;padding:4px 8px;" onclick="quickFill(<%= ai %>, '困ってたら相談してね')">相談してね</button>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
    <% } %>

    <!-- Stats -->
    <%
      let totalTasks = 0, completedTasks = 0, delayedMembers = 0, totalMembers = 0;
      teams.forEach(td => {
        td.memberTasks.forEach(mt => {
          totalMembers++;
          totalTasks += mt.tasks.length;
          completedTasks += mt.tasks.filter(t => t.status === 'completed').length;
          if (mt.hasDelay) delayedMembers++;
        });
      });
      const overallProg = totalTasks > 0 ? Math.round(completedTasks / totalTasks * 100) : 0;
    %>
    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-value"><%= teams.length %></div>
        <div class="stat-label">チーム数</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= totalMembers %></div>
        <div class="stat-label">稼働人数</div>
      </div>
      <div class="stat-card <%= overallProg < 40 && phase.phase >= 3 ? 'danger' : '' %>">
        <div class="stat-value"><%= overallProg %>%</div>
        <div class="stat-label">全体完了率</div>
      </div>
      <div class="stat-card <%= delayedMembers > 0 ? 'danger' : 'success' %>">
        <div class="stat-value"><%= delayedMembers %></div>
        <div class="stat-label">遅延メンバー</div>
      </div>
    </div>

    <!-- Teams -->
    <% if (teams.length === 0) { %>
      <div class="card">
        <div class="card-body" style="text-align:center;padding:60px;">
          <p style="color:var(--gray-400);font-size:18px;margin-bottom:16px;">本日のチームが未編成です</p>
          <a href="/team-setup?date=<%= selectedDate %>" class="btn btn-primary">チームを編成する</a>
        </div>
      </div>
    <% } %>

    <% teams.forEach(td => {
      const teamTotalTasks = td.memberTasks.reduce((s, mt) => s + mt.tasks.length, 0);
      const teamCompletedTasks = td.memberTasks.reduce((s, mt) => s + mt.tasks.filter(t => t.status === 'completed').length, 0);
      const teamProgress = teamTotalTasks > 0 ? Math.round(teamCompletedTasks / teamTotalTasks * 100) : 0;
      const teamAvgProgress = td.memberTasks.length > 0 ? Math.round(td.memberTasks.reduce((s, mt) => s + mt.progress, 0) / td.memberTasks.length) : 0;
    %>
      <div class="team-card">
        <div class="team-card-header">
          <h3><%= td.team.name %>
            <span style="font-size:14px;font-weight:700;margin-left:12px;color:<%= teamAvgProgress >= 80 ? '#22c55e' : teamAvgProgress >= 40 ? '#f59e0b' : '#ef4444' %>;">
              <span style="font-size:11px;letter-spacing:1px;opacity:0.8;">PROGRESS</span> <%= teamAvgProgress %>%
            </span>
          </h3>
          <div style="display:flex;gap:12px;align-items:center;">
            <span class="team-leader-badge"><%= td.leader ? td.leader.name : '未設定' %></span>
            <span style="font-size:13px;opacity:0.8;"><%= td.memberTasks.length %>名</span>
            <span style="font-size:13px;opacity:0.8;">完了 <%= teamCompletedTasks %>/<%= teamTotalTasks %></span>
          </div>
        </div>
        <div style="padding:0 16px;">
          <div class="progress-bar-wrap" style="height:6px;margin:0;">
            <div class="progress-bar-fill <%= teamAvgProgress < 30 ? 'low' : teamAvgProgress < 70 ? 'mid' : 'high' %>" style="width:<%= teamAvgProgress %>%"></div>
          </div>
        </div>
        <div style="padding:16px;">
          <% td.memberTasks.forEach(mt => { %>
            <div class="member-card <%= mt.hasDelay ? 'has-delay' : '' %>">
              <div class="member-card-header" onclick="this.nextElementSibling.classList.toggle('open')">
                <div style="display:flex;align-items:center;gap:12px;flex:1;min-width:0;">
                  <div class="member-name-with-avatar">
                    <%- avatarHtml(mt.user, 'sm') %>
                    <span class="member-name">
                      <%= mt.user.name %>
                      <% if (mt.user.id === td.team.leader_id) { %><span style="font-size:10px;background:var(--gray-700);color:white;padding:1px 6px;border-radius:4px;font-weight:600;letter-spacing:0.5px;">L</span><% } %>
                    </span>
                  </div>
                  <div class="member-progress-inline">
                    <div class="member-progress-fill <%= mt.progress < 30 ? 'low' : mt.progress < 70 ? 'mid' : 'high' %>" style="width:<%= mt.progress %>%"></div>
                  </div>
                  <span style="font-weight:700;font-size:15px;min-width:42px;text-align:right;color:<%= mt.progress >= 80 ? 'var(--success)' : mt.progress >= 40 ? 'var(--warning)' : 'var(--danger)' %>;">
                    <%= mt.progress %>%
                  </span>
                  <% if (mt.hasDelay) { %><span style="color:var(--danger);font-size:12px;white-space:nowrap;">遅延</span><% } %>
                  <% if (mt.hasQuestions) { %><span style="color:var(--primary);font-size:12px;white-space:nowrap;">❓質問</span><% } %>
                </div>
                <div class="member-stats">
                  <span><%= mt.tasks.length %>タスク</span>
                  <span>見積<%= fmtMin(mt.totalEst) %></span>
                  <span>実績<%= fmtMin(mt.totalActual) %></span>
                  <span style="font-size:12px;color:var(--gray-400);">▼</span>
                </div>
              </div>
              <div class="member-card-body">
                <div class="progress-bar-wrap" style="margin-bottom:12px;">
                  <div class="progress-bar-fill <%= mt.progress < 30 ? 'low' : mt.progress < 70 ? 'mid' : 'high' %>" style="width:<%= mt.progress %>%"></div>
                </div>
                <% if (mt.tasks.length === 0) { %>
                  <p style="color:var(--gray-400);font-size:13px;text-align:center;padding:16px;">タスク未登録</p>
                <% } %>
                <% mt.tasks.forEach((task, i) => { %>
                  <div class="task-item <%= task.status === 'completed' ? 'completed' : '' %> <%= task.actual_minutes > task.estimated_minutes && task.progress < 100 ? 'delayed' : '' %>">
                    <div class="task-top">
                      <span class="task-title"><%= i + 1 %>. <%= task.title %></span>
                      <span class="task-category"><%= task.category %></span>
                    </div>
                    <div class="task-meta">
                      <span>見積: <%= fmtMin(task.estimated_minutes) %></span>
                      <span>実績: <%= fmtMin(task.actual_minutes) %></span>
                      <span>
                        <% if (task.status === 'completed') { %>
                          <span style="color:var(--success);font-weight:600;">✓ 完了</span>
                        <% } else if (task.status === 'blocked') { %>
                          <span style="color:var(--danger);font-weight:600;">🚫 ブロック</span>
                        <% } else if (task.status === 'in_progress') { %>
                          <span style="color:var(--primary);font-weight:600;">▶ 作業中</span>
                        <% } else { %>
                          <span style="color:var(--gray-400);">○ 未着手</span>
                        <% } %>
                      </span>
                    </div>
                    <div class="progress-bar-wrap" style="height:8px;">
                      <div class="progress-bar-fill <%= task.progress < 30 ? 'low' : task.progress < 70 ? 'mid' : 'high' %>" style="width:<%= task.progress %>%"></div>
                    </div>
                    <div class="progress-label" style="color:<%= task.progress < 30 ? 'var(--danger)' : task.progress < 70 ? 'var(--warning)' : 'var(--success)' %>"><%= task.progress %>%</div>
                    <% if (task.actual_minutes > task.estimated_minutes) { %>
                      <div style="font-size:12px;color:var(--danger);margin-top:4px;">見積超過: +<%= fmtMin(task.actual_minutes - task.estimated_minutes) %></div>
                    <% } %>
                    <div class="comments-section" style="margin-top:8px;">
                      <button class="btn btn-sm btn-outline" onclick="toggleManagerComments(<%= task.id %>, this)">Comment</button>
                      <div class="manager-comments" id="mgr-comments-<%= task.id %>" style="display:none;margin-top:8px;">
                        <div id="mgr-comments-list-<%= task.id %>"></div>
                        <div class="comment-input">
                          <input type="text" placeholder="コメントを入力..." id="mgr-comment-text-<%= task.id %>">
                          <button class="btn btn-sm btn-primary" onclick="addManagerComment(<%= task.id %>)">送信</button>
                        </div>
                      </div>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% }) %>

    <!-- User Management -->
    <div class="card" style="margin-top:24px;">
      <div class="card-header">
        <h2>メンバー管理</h2>
        <button class="btn btn-sm btn-primary" onclick="document.getElementById('add-user-modal').classList.add('active')">+ メンバー追加</button>
      </div>
      <div class="card-body">
        <table style="width:100%;font-size:14px;border-collapse:collapse;">
          <thead>
            <tr style="border-bottom:2px solid var(--gray-200);text-align:left;">
              <th style="padding:8px;">名前</th>
              <th style="padding:8px;">ログインID</th>
              <th style="padding:8px;">権限</th>
            </tr>
          </thead>
          <tbody>
            <% allUsers.forEach(u => { %>
            <tr style="border-bottom:1px solid var(--gray-100);">
              <td style="padding:8px;font-weight:600;">
                <div class="member-name-with-avatar">
                  <%- avatarHtml(u, 'sm') %>
                  <span><%= u.name %></span>
                </div>
              </td>
              <td style="padding:8px;color:var(--gray-500);"><%= u.login_id %></td>
              <td style="padding:8px;">
                <span class="badge" style="background:<%= u.role === 'manager' ? 'var(--danger-light);color:var(--danger)' : u.role === 'leader' ? 'var(--warning-light);color:#92400e' : 'var(--gray-100);color:var(--gray-600)' %>;padding:2px 10px;border-radius:8px;font-size:12px;font-weight:600;">
                  <%= u.role === 'manager' ? 'マネージャー' : u.role === 'leader' ? 'リーダー' : 'メンバー' %>
                </span>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Add User Modal -->
  <div class="modal-overlay" id="add-user-modal">
    <div class="modal">
      <div class="modal-header">
        <h3>メンバー追加</h3>
        <button class="modal-close" onclick="this.closest('.modal-overlay').classList.remove('active')">×</button>
      </div>
      <div class="modal-body">
        <div class="form-group">
          <label>名前</label>
          <input type="text" id="new-user-name" placeholder="山田太郎">
        </div>
        <div class="form-group">
          <label>ログインID</label>
          <input type="text" id="new-user-login" placeholder="yamada">
        </div>
        <div class="form-group">
          <label>パスワード</label>
          <input type="text" id="new-user-pass" value="pass1234">
        </div>
        <div class="form-group">
          <label>権限</label>
          <select id="new-user-role">
            <option value="member">メンバー</option>
            <option value="leader">リーダー</option>
            <option value="manager">マネージャー</option>
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline" onclick="this.closest('.modal-overlay').classList.remove('active')">キャンセル</button>
        <button class="btn btn-primary" onclick="addUser()">追加</button>
      </div>
    </div>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/app.js"></script>
  <script>
    const socket = io();
    socket.on('task-updated', () => location.reload());
    socket.on('report-submitted', () => location.reload());

    function toggleManagerComments(taskId, btn) {
      const el = document.getElementById('mgr-comments-' + taskId);
      el.style.display = el.style.display === 'none' ? 'block' : 'none';
      if (el.style.display === 'block') loadComments(taskId, 'mgr-comments-list-' + taskId);
    }
    function addManagerComment(taskId) {
      const input = document.getElementById('mgr-comment-text-' + taskId);
      if (!input.value.trim()) return;
      fetch('/api/tasks/' + taskId + '/comments', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ message: input.value, is_question: false })
      }).then(r => r.json()).then(d => {
        input.value = '';
        renderComments(d.comments, 'mgr-comments-list-' + taskId);
      });
    }
    // === Alert dismiss ===
    function getDismissedAlerts() {
      try { return JSON.parse(localStorage.getItem('dismissedAlerts') || '{}'); } catch(e) { return {}; }
    }
    function dismissAlert(idx) {
      const el = document.getElementById('alert-item-' + idx);
      if (!el) return;
      const key = el.dataset.alertKey;
      const dismissed = getDismissedAlerts();
      dismissed[key] = Date.now();
      localStorage.setItem('dismissedAlerts', JSON.stringify(dismissed));
      el.style.transition = 'opacity 0.3s, max-height 0.3s, padding 0.3s, margin 0.3s';
      el.style.opacity = '0';
      el.style.maxHeight = '0';
      el.style.padding = '0 16px';
      el.style.marginBottom = '0';
      el.style.overflow = 'hidden';
      setTimeout(() => { el.remove(); updateAlertCount(); }, 300);
    }
    function dismissAllAlerts() {
      const dismissed = getDismissedAlerts();
      document.querySelectorAll('.alert-item').forEach(el => {
        dismissed[el.dataset.alertKey] = Date.now();
        el.style.transition = 'opacity 0.3s';
        el.style.opacity = '0';
        setTimeout(() => el.remove(), 300);
      });
      localStorage.setItem('dismissedAlerts', JSON.stringify(dismissed));
      setTimeout(() => {
        const panel = document.getElementById('alert-panel');
        if (panel) panel.style.display = 'none';
      }, 350);
    }
    function updateAlertCount() {
      const remaining = document.querySelectorAll('.alert-item').length;
      const countEl = document.getElementById('alert-count');
      if (countEl) countEl.textContent = remaining;
      if (remaining === 0) {
        const panel = document.getElementById('alert-panel');
        if (panel) panel.style.display = 'none';
      }
    }
    // On load: hide previously dismissed alerts
    (function() {
      const dismissed = getDismissedAlerts();
      // Clean old entries (older than 24h)
      const cutoff = Date.now() - 24 * 60 * 60 * 1000;
      Object.keys(dismissed).forEach(k => { if (dismissed[k] < cutoff) delete dismissed[k]; });
      localStorage.setItem('dismissedAlerts', JSON.stringify(dismissed));
      document.querySelectorAll('.alert-item').forEach(el => {
        if (dismissed[el.dataset.alertKey]) el.remove();
      });
      updateAlertCount();
    })();

    function toggleAlertReply(idx) {
      const el = document.getElementById('alert-reply-' + idx);
      const isOpen = el.style.display !== 'none';
      // Close all others
      document.querySelectorAll('.alert-reply').forEach(r => r.style.display = 'none');
      if (!isOpen) {
        el.style.display = 'block';
        document.getElementById('alert-input-' + idx).focus();
      }
    }
    function quickFill(idx, text) {
      document.getElementById('alert-input-' + idx).value = text;
    }
    function sendAlertComment(idx, taskId, userName) {
      const input = document.getElementById('alert-input-' + idx);
      const msg = input.value.trim();
      if (!msg) return;
      if (!taskId) { alert('コメント先のタスクがありません'); return; }
      fetch('/api/tasks/' + taskId + '/comments', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ message: '📢 ' + msg, is_question: false })
      }).then(r => r.json()).then(d => {
        if (d.ok) {
          input.value = '';
          document.getElementById('alert-reply-' + idx).style.display = 'none';
          // Show success feedback
          const alertEl = document.getElementById('alert-reply-' + idx).parentElement;
          const badge = document.createElement('span');
          badge.style.cssText = 'background:#22c55e;color:white;padding:2px 8px;border-radius:8px;font-size:11px;margin-left:8px;';
          badge.textContent = '✓ ' + userName + 'さんに送信済み';
          alertEl.querySelector('span:nth-child(2)').appendChild(badge);
        }
      });
    }
    function uploadAvatar(input, userId) {
      if (!input.files[0]) return;
      const formData = new FormData();
      formData.append('avatar', input.files[0]);
      fetch('/api/users/' + userId + '/avatar', { method: 'POST', body: formData })
        .then(r => r.json()).then(d => { if (d.ok) location.reload(); });
    }
    function addUser() {
      const name = document.getElementById('new-user-name').value;
      const login_id = document.getElementById('new-user-login').value;
      const password = document.getElementById('new-user-pass').value;
      const role = document.getElementById('new-user-role').value;
      if (!name || !login_id) return alert('名前とログインIDは必須です');
      fetch('/api/users', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ name, login_id, password, role })
      }).then(r => r.json()).then(d => {
        if (d.ok) location.reload();
        else alert(d.error);
      });
    }
  </script>
</body>
</html>
